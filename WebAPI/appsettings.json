{
  "ConnectionStrings": {
    "SqlServerConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=GenericRepositoryDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Cache": {
    "RedisConfiguration": "localhost:6379",
    "RedisInstanceName": "AppCache_"
  },
  "Jwt": {
    "Issuer": "develop.auth",
    "Audience": "develop.app",
    "SecretKey": "supersecretdevelopkey12345678910111213",
    "AccessTokenExpirationMinutes": "30"
  },
  "Csrf": {
    "CookieName": "XSRF-TOKEN",
    "HeaderName": "X-CSRF-TOKEN",
    "MethodsToCheck": [ "POST", "PUT", "DELETE" ],
    "ExemptPaths": [ "/api/auth/login", "/api/auth/logout", "/api/auth/register", "/api/auth/refresh-token"],
    "SecretKey": "csrf-secret-key-change-in-production-12345"
  },
  "Queue": {
    "RabbitMqHost": "localhost",
    "RabbitMqUsername": "guest",
    "RabbitMqPassword": "guest"
  },
  "CookieToken": {
    "AccessTokenCookieName": "accessToken",
    "RefreshTokenCookieName": "refreshToken",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "FileLogging": {
    "InfoLogPath": "Logs/Info/log-.txt",
    "WarningLogPath": "Logs/Warning/log-.txt",
    "ErrorLogPath": "Logs/Error/log-.txt"
  },
  "AuthMiddleware": {
    "AnonymousPaths": [
      "/swagger",
      "/swagger/index.html",
      "/swagger/v1/swagger.json",
      "/api/auth/login",
      "/api/auth/register",
      "/api/auth/refresh-token"
    ]
  },
  "SecurityHeader": {
    "DevelopmentCsp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ws://localhost:* wss://localhost:*;",
    "ProductionCsp": "default-src 'self'; script-src 'self'; object-src 'none'; frame-ancestors 'none';"
  },
  "Localization": {
    "DefaultCulture": "en",
    "SupportedCultures": [ "en", "tr" ]
  },
  "WebClient": {
    "TrustedOrigins": [ "://localhost:5000" ]
  }
}
